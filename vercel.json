{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/handler.ts": {
      "maxDuration": 60,
      "includeFiles": "server/drizzle/**"
    }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api/handler" },
    { "source": "/api/v1/(.*)", "destination": "/api/handler" },
    { "source": "/((?!api/|assets/|thinkloop-logo|.*\\..*).*)", "destination": "/index.html" }
  ]
}
