# Copy to .env for local development (never commit .env)

# OpenRouter — powers the organize + email agents
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional: Turso (Vercel / remote SQLite)
# TURSO_DATABASE_URL=libsql://your-db-name-org.turso.io
# TURSO_AUTH_TOKEN=your-turso-token

# Fly.io / Docker — SQLite file on mounted volume (set in fly.toml)
# DB_PATH=/data/thinkloop.db

# Optional
# PORT=3001
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
